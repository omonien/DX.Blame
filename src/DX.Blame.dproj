<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
    <PropertyGroup>
        <Base>True</Base>
        <AppType>Package</AppType>
        <Config Condition="'$(Config)'==''">Debug</Config>
        <FrameworkType>None</FrameworkType>
        <MainSource>DX.Blame.dpk</MainSource>
        <Platform Condition="'$(Platform)'==''">Win32</Platform>
        <ProjectGuid>{A1B2C3D4-E5F6-7890-ABCD-EF1234567890}</ProjectGuid>
        <ProjectName Condition="'$(ProjectName)'==''">DX.Blame</ProjectName>
        <ProjectVersion>20.3</ProjectVersion>
        <TargetedPlatforms>3</TargetedPlatforms>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Config)'=='Base' or '$(Base)'!=''">
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="('$(Platform)'=='Win32' and '$(Base)'=='true') or '$(Base_Win32)'!=''">
        <Base_Win32>true</Base_Win32>
        <CfgParent>Base</CfgParent>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="('$(Platform)'=='Win64' and '$(Base)'=='true') or '$(Base_Win64)'!=''">
        <Base_Win64>true</Base_Win64>
        <CfgParent>Base</CfgParent>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Config)'=='Debug' or '$(Cfg_1)'!=''">
        <Cfg_1>true</Cfg_1>
        <CfgParent>Base</CfgParent>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Config)'=='Release' or '$(Cfg_2)'!=''">
        <Cfg_2>true</Cfg_2>
        <CfgParent>Base</CfgParent>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Base)'!=''">
        <SanitizedProjectName>DX_Blame</SanitizedProjectName>
        <DllSuffix>$(Auto)</DllSuffix>
        <GenDll>true</GenDll>
        <GenPackage>true</GenPackage>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Base_Win32)'!=''">
        <DCC_UsePackage>vcl;rtl;$(DCC_UsePackage)</DCC_UsePackage>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Base_Win64)'!=''">
        <DCC_UsePackage>vcl;rtl;$(DCC_UsePackage)</DCC_UsePackage>
    </PropertyGroup>
    <ItemGroup>
        <DelphiCompile Include="$(MainSource)">
            <MainSource>MainSource</MainSource>
        </DelphiCompile>
        <DCCReference Include="..\res\DX.Blame.Splash.res"/>
        <DCCReference Include="rtl.dcp"/>
        <DCCReference Include="vcl.dcp"/>
        <DCCReference Include="designide.dcp"/>
        <DCCReference Include="DX.Blame.Version.pas"/>
        <DCCReference Include="DX.Blame.VCS.Types.pas"/>
        <DCCReference Include="DX.Blame.VCS.Process.pas"/>
        <DCCReference Include="DX.Blame.VCS.Provider.pas"/>
        <DCCReference Include="DX.Blame.Git.Types.pas"/>
        <DCCReference Include="DX.Blame.Git.Discovery.pas"/>
        <DCCReference Include="DX.Blame.Git.Process.pas"/>
        <DCCReference Include="DX.Blame.Git.Blame.pas"/>
        <DCCReference Include="DX.Blame.Git.Provider.pas"/>
        <DCCReference Include="DX.Blame.Hg.Discovery.pas"/>
        <DCCReference Include="DX.Blame.Hg.Types.pas"/>
        <DCCReference Include="DX.Blame.Hg.Process.pas"/>
        <DCCReference Include="DX.Blame.Hg.Blame.pas"/>
        <DCCReference Include="DX.Blame.Hg.Provider.pas"/>
        <DCCReference Include="DX.Blame.VCS.Discovery.pas"/>
        <DCCReference Include="DX.Blame.Cache.pas"/>
        <DCCReference Include="DX.Blame.Settings.pas"/>
        <DCCReference Include="DX.Blame.Formatter.pas"/>
        <DCCReference Include="DX.Blame.CommitDetail.pas"/>
        <DCCReference Include="DX.Blame.Popup.pas">
            <Form>DXBlamePopup</Form>
            <FormType>dfm</FormType>
        </DCCReference>
        <DCCReference Include="DX.Blame.Diff.Form.pas">
            <Form>FormDXBlameDiff</Form>
            <FormType>dfm</FormType>
        </DCCReference>
        <DCCReference Include="DX.Blame.Renderer.pas"/>
        <DCCReference Include="DX.Blame.Statusbar.pas"/>
        <DCCReference Include="DX.Blame.KeyBinding.pas"/>
        <DCCReference Include="DX.Blame.Navigation.pas"/>
        <DCCReference Include="DX.Blame.Settings.Frame.pas">
            <Form>FrameDXBlameSettings</Form>
            <FormType>dfm</FormType>
            <DesignClass>TFrame</DesignClass>
        </DCCReference>
        <DCCReference Include="DX.Blame.Settings.Options.pas"/>
        <DCCReference Include="DX.Blame.Settings.Form.pas">
            <Form>FormDXBlameSettings</Form>
            <FormType>dfm</FormType>
        </DCCReference>
        <DCCReference Include="DX.Blame.Engine.pas"/>
        <DCCReference Include="DX.Blame.IDE.Notifier.pas"/>
        <DCCReference Include="DX.Blame.Registration.pas"/>
        <BuildConfiguration Include="Base">
            <Key>Base</Key>
        </BuildConfiguration>
        <BuildConfiguration Include="Debug">
            <Key>Cfg_1</Key>
            <CfgParent>Base</CfgParent>
        </BuildConfiguration>
        <BuildConfiguration Include="Release">
            <Key>Cfg_2</Key>
            <CfgParent>Base</CfgParent>
        </BuildConfiguration>
    </ItemGroup>
    <ProjectExtensions>
        <Borland.Personality>Delphi.Personality.12</Borland.Personality>
        <Borland.ProjectType>Package</Borland.ProjectType>
        <BorlandProject>
            <Delphi.Personality>
                <Source>
                    <Source Name="MainSource">DX.Blame.dpk</Source>
                </Source>
                <Excluded_Packages/>
            </Delphi.Personality>
            <Platforms>
                <Platform value="Android">False</Platform>
                <Platform value="Android64">False</Platform>
                <Platform value="Linux64">False</Platform>
                <Platform value="Win32">True</Platform>
                <Platform value="Win64">True</Platform>
                <Platform value="Win64x">False</Platform>
                <Platform value="iOSDevice64">False</Platform>
                <Platform value="iOSSimARM64">False</Platform>
            </Platforms>
            <VersionInfo>
                <VersionInfo Name="IncludeVerInfo">True</VersionInfo>
                <VersionInfo Name="AutoIncBuild">False</VersionInfo>
                <VersionInfo Name="MajorVer">1</VersionInfo>
                <VersionInfo Name="MinorVer">2</VersionInfo>
                <VersionInfo Name="Release">1</VersionInfo>
                <VersionInfo Name="Build">0</VersionInfo>
                <VersionInfo Name="Debug">False</VersionInfo>
                <VersionInfo Name="PreRelease">False</VersionInfo>
                <VersionInfo Name="Special">False</VersionInfo>
                <VersionInfo Name="Private">False</VersionInfo>
                <VersionInfo Name="DLL">True</VersionInfo>
                <VersionInfo Name="Locale">1031</VersionInfo>
                <VersionInfo Name="CodePage">1252</VersionInfo>
            </VersionInfo>
            <VersionInfoKeys>
                <VersionInfoKeys Name="CompanyName">Olaf Monien</VersionInfoKeys>
                <VersionInfoKeys Name="FileDescription">DX.Blame - VCS Blame for Delphi</VersionInfoKeys>
                <VersionInfoKeys Name="FileVersion">1.2.1.0</VersionInfoKeys>
                <VersionInfoKeys Name="InternalName">DX.Blame</VersionInfoKeys>
                <VersionInfoKeys Name="LegalCopyright">Copyright (c) 2026 Olaf Monien</VersionInfoKeys>
                <VersionInfoKeys Name="LegalTrademarks"/>
                <VersionInfoKeys Name="OriginalFilename">DX.Blame.bpl</VersionInfoKeys>
                <VersionInfoKeys Name="ProductName">DX.Blame</VersionInfoKeys>
                <VersionInfoKeys Name="ProductVersion">1.2.1.0</VersionInfoKeys>
                <VersionInfoKeys Name="Comments">MIT License</VersionInfoKeys>
            </VersionInfoKeys>
        </BorlandProject>
        <ProjectFileVersion>12</ProjectFileVersion>
    </ProjectExtensions>
    <Import Project="$(BDS)\Bin\CodeGear.Delphi.Targets" Condition="Exists('$(BDS)\Bin\CodeGear.Delphi.Targets')"/>
    <Import Project="$(APPDATA)\Embarcadero\$(BDSAPPID)\$(ProductVersion)\UserTools.proj" Condition="Exists('$(APPDATA)\Embarcadero\$(BDSAPPID)\$(ProductVersion)\UserTools.proj')"/>
    <Import Project="$(MSBuildProjectName).deployproj" Condition="Exists('$(MSBuildProjectName).deployproj')"/>
    <Import Project="$(APPDATA)\Embarcadero\$(BDSAPPDATABASEDIR)\$(PRODUCTVERSION)\UserTools.proj" Condition="Exists('$(APPDATA)\Embarcadero\$(BDSAPPDATABASEDIR)\$(PRODUCTVERSION)\UserTools.proj')"/>
</Project>
